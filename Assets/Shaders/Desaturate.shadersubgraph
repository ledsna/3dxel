    "m_SourceType": 0,
    "m_FunctionName": "Desaturate",
    "m_FunctionSource": "988733fd9870440368aabf18a40ef9ee",
    "m_FunctionBody": "void Desaturate_float4(float4 inputColor, float desaturationFactor, out float4 result) {\n    // Clamp desaturationFactor to the range [0, 1]\n    desaturationFactor = saturate(desaturationFactor);\n\n    // Calculate the luminance of the input color\n    float luminance = 0.3 * inputColor.r + 0.59 * inputColor.g + 0.11 * inputColor.b;\n\n    // Interpolate between the input color and the greyscale color\n    result.r = lerp(inputColor.r, luminance, desaturationFactor);\n    result.g = lerp(inputColor.g, luminance, desaturationFactor);\n    result.b = lerp(inputColor.b, luminance, desaturationFactor);\n    result.a = inputColor.a; // Preserve the alpha channel\n}"
}

